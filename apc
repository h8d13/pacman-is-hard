set -euo pipefail

# case signals reach: lowercase stays inside the script, UPPER crosses into env.
# local vars lowercase, no prefix. internal globals lowercase, prefix with _.
# env-overridable vars (collision risk) UPPER, prefix APC_, with a default.
# quote vars with "" and brace them {} when appropriate.

_ver_string="dev"
_use_color=1
_arrow="==>"

# Color codes
_green='\033[0;32m'
_yellow='\033[1;33m'
_nc='\033[0m'
style() {
	local text="${1}"
	local color="${2}"
	if [[ ${_use_color} -eq 1 ]]; then
		echo -e "${color}${text}${_nc}"
	else
		echo "${text}"
	fi
}

op_a() {
	local text="${1}"
	echo "$(style "${_arrow}" "${_green}") ${text}..."
}

# Elevation options (priority order)
# For GUI prompts you can put run0 first.
_elevate=""
for cmd in sudo doas run0 su; do
	if command -v "${cmd}" &>/dev/null; then
		_elevate="${cmd}"
		break
	fi
done

# Elevation wrapper
needs_elev() {
	if [[ ${EUID} -eq 0 ]]; then
		"$@"
	elif [[ -z "${_elevate}" ]]; then
		echo "error: root required but no elevation tool found (sudo, doas, run0, su)" >&2
		return 1
	elif [[ "${_elevate}" == "su" ]]; then
		# su takes a command string, not argv like the others
		su -c "$(printf '%q ' "$@")"
	else
		"${_elevate}" "$@"
	fi
}

# pacman-contrib operations
check_updates() {
	op_a 'checking updates'
	local rc=0
	checkupdates "$@" || rc=$?
	# checkupdates exits 2 when there is nothing to do; 1 is a real error
	if [[ ${rc} -eq 2 ]]; then
		op_a 'system up to date'
	elif [[ ${rc} -ne 0 ]]; then
		return "${rc}"
	fi
}

clean_packages() {
	op_a 'cleaning packages'
	needs_elev paccache -r "$@"
}

# Remove orphans: packages installed as deps that nothing requires anymore.
# pacman -Qdtq exits 1 when none are found, so an empty result is not an error.
remove_orphans() {
	op_a 'finding orphans'
	local orphans=()
	mapfile -t orphans < <(pacman -Qdtq)
	if [[ ${#orphans[@]} -eq 0 ]]; then
		op_a 'no orphans found'
		return 0
	fi
	needs_elev pacman -Rns "$@" "${orphans[@]}"
}

show_dependencies() {
	op_a 'showing deps'
	pactree "$@"
}

# Repository overview from pacman.conf: bare [repo] enabled, #[repo] disabled.
list_repos() {
	local conf="/etc/pacman.conf"
	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--config)
			conf="${2}"
			shift 2
			;;
		*)
			echo "error: unknown option '${1}' (expected --config FILE)" >&2
			return 1
			;;
		esac
	done
	if [[ ! -r "${conf}" ]]; then
		echo "error: cannot read ${conf}" >&2
		return 1
	fi
	op_a "reading repos from ${conf}"
	while IFS= read -r line; do
		if [[ "${line}" =~ ^[[:space:]]*\[([^]]+)\][[:space:]]*$ ]]; then
			[[ "${BASH_REMATCH[1]}" == options ]] && continue
			style "  [${BASH_REMATCH[1]}] enabled" "${_green}"
		elif [[ "${line}" =~ ^#\[([^]]+)\][[:space:]]*$ ]]; then
			[[ "${BASH_REMATCH[1]}" == options ]] && continue
			style "  [${BASH_REMATCH[1]}] disabled" "${_yellow}"
		fi
	done <"${conf}"
}

# reflector operations
sort_mirrors() {
	local save="/etc/pacman.d/mirrorlist"
	local dry_run=0
	local extra=()

	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--dry-run) dry_run=1 ;;
		*) extra+=("${1}") ;; # pass reflector's own flags through
		esac
		shift
	done

	# Defaults first so passed-through flags can override them
	local cmd=("reflector" "--protocol" "https" "--latest" "20" "--sort" "rate" "${extra[@]}")

	if [[ ${dry_run} -eq 1 ]]; then
		op_a 'sorting mirrors with reflector (dry run)'
		"${cmd[@]}"
	else
		op_a 'sorting mirrors with reflector'
		needs_elev "${cmd[@]}" --save "${save}"
	fi
}

APC_PACMAN_LOCAL="${APC_PACMAN_LOCAL:-/var/lib/pacman/local}"

# Package listing. Flags pick a query mode; last one wins. -Ql/-Qo take a
# trailing argument (a pkg name / a file path) which arrives via extra.
# --first/--last read install/upgrade order from local-db dir mtimes (like ls -t).
list_packages() {
	local flag="-Sl" msg='listing sync packages' extra=()
	local order="" count=20

	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--local | -l) flag="-Q" msg='listing installed packages' ;;
		--explicit | -e) flag="-Qe" msg='listing explicit packages' ;;
		--files | -f) flag="-Ql" msg='listing files owned by package' ;;
		--why | -w) flag="-Qo" msg='finding package that owns file' ;;
		--last) order="-t" msg='listing newest installed packages' ;;
		--first) order="-tr" msg='listing oldest installed packages' ;;
		[0-9]*) count="${1}" ;; # count for --first/--last
		*) extra+=("${1}") ;;   # pass pacman's own flags / the target through
		esac
		shift
	done

	op_a "${msg}"
	if [[ -n "${order}" ]]; then
		# Pkg dirs are name-version-rel (always hyphenated); skips ALPM_DB_VERSION.
		# ls -t/-tr sorts by mtime (install/upgrade order), which find/globs can't.
		# shellcheck disable=SC2010,SC2012
		ls "${order}" "${APC_PACMAN_LOCAL}" | grep -- - | head -n "${count}"
		return
	fi
	pacman "${flag}" "${extra[@]}"
}

# Package search
search_packages() {
	local package="${1}" flag local_search=0 extra=()
	shift

	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--local | -l) local_search=1 ;;
		*) extra+=("${1}") ;; # pass pacman's own flags through
		esac
		shift
	done

	if [[ ${local_search} -eq 1 ]]; then
		flag="-Qs"
		op_a "[?] searching local packages for ${package}"
	else
		flag="-Ss"
		op_a "[?] searching sync repos for ${package}"
	fi

	pacman "${flag}" "${extra[@]}" "${package}"
}

# Package inspection. Flags pick a mode; the target is a pkg name, except for
# --why/-F where it is a file path. Parsed position-independently so the flag
# may come before the target.
inspect_package() {
	local flag="-Sii" mode='inspecting sync' extra=() target="" files_db=0

	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--local | -l) flag="-Qii" mode='inspecting installed' ;;
		--files | -f) flag="-Fl" mode='listing files provided by' files_db=1 ;;
		--why | -w) flag="-F" mode='finding package providing' files_db=1 ;;
		-*) extra+=("${1}") ;; # pass pacman's own flags through
		*) target="${1}" ;;    # pkg name or file path
		esac
		shift
	done

	# -F queries read the files database; refresh it first (writes db, needs root).
	if [[ ${files_db} -eq 1 ]]; then
		op_a 'syncing files database'
		needs_elev pacman -Fy
	fi
	op_a "${mode} ${target}"
	pacman "${flag}" "${extra[@]}" "${target}"
}

# Package installation
install_package() {
	local package="${1}"
	shift
	op_a "installing ${package}"
	needs_elev pacman -S "$@" "${package}"
}

# Package removal
remove_package() {
	local package="${1}" dependencies=1 extra=()
	shift
	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--no-deps) dependencies=0 ;;
		*) extra+=("${1}") ;; # pass pacman's own flags through
		esac
		shift
	done
	op_a "uninstalling ${package}"
	local flag="-Rns"
	[[ ${dependencies} -eq 0 ]] && flag="-R"
	needs_elev pacman "${flag}" "${extra[@]}" "${package}"
}

# Main function
main() {
	# Parse global options
	while [[ $# -gt 0 ]]; do
		case "${1}" in
		--no-color)
			_use_color=0
			shift
			;;
		*)
			# command, help/version flag, or unknown: let the command esac decide
			break
			;;
		esac
	done

	# Get command and its arguments
	local command="${1:-}"
	shift 2>/dev/null || true
	local cmd_args=("$@")

	case "${command}" in
	mirrors)
		sort_mirrors "${cmd_args[@]}"
		;;
	update)
		op_a 'syncing system'
		needs_elev pacman -Syy "${cmd_args[@]}"
		;;
	upgrade)
		op_a 'upgrading system'
		needs_elev pacman -Syu "${cmd_args[@]}"
		;;
	check)
		check_updates "${cmd_args[@]}"
		;;
	clean)
		clean_packages "${cmd_args[@]}"
		;;
	orphs)
		remove_orphans "${cmd_args[@]}"
		;;
	deps)
		if [[ -z "${cmd_args[0]}" ]]; then
			echo "error: deps requires a package name" >&2
			return 1
		fi
		show_dependencies "${cmd_args[@]}"
		;;
	repos)
		list_repos "${cmd_args[@]}"
		;;
	list)
		list_packages "${cmd_args[@]}"
		;;
	search)
		if [[ -z "${cmd_args[0]}" ]]; then
			echo "error: search requires a package name" >&2
			return 1
		fi
		search_packages "${cmd_args[0]}" "${cmd_args[@]:1}"
		;;
	info)
		if [[ -z "${cmd_args[0]}" ]]; then
			echo "error: info requires a package name" >&2
			return 1
		fi
		inspect_package "${cmd_args[0]}" "${cmd_args[@]:1}"
		;;
	install)
		if [[ -z "${cmd_args[0]}" ]]; then
			echo "error: install requires a package name" >&2
			return 1
		fi
		local pkg="${cmd_args[0]}"
		# pkg- syntax means uninstall (like apt)
		if [[ "${pkg}" == *- ]]; then
			remove_package "${pkg%-}" "${cmd_args[@]:1}"
		else
			install_package "${pkg}" "${cmd_args[@]:1}"
		fi
		;;
	uninstall)
		if [[ -z "${cmd_args[0]}" ]]; then
			echo "error: uninstall requires a package name" >&2
			return 1
		fi
		remove_package "${cmd_args[0]}" "${cmd_args[@]:1}"
		;;
	-v | --version | version)
		echo "Apc ${_ver_string} - 0BSD" && echo ""
		pacman -V
		return 0
		;;
	'')
		# No args at all: defer to pacman's own usage/output, don't search.
		pacman "${cmd_args[@]}"
		;;
	-h | --help | help)
		# Help text is the header comment block: '# NAME' to the first blank line.
		# Anything above NAME (shebang, meta-comments) is excluded.
		# Strip one-or-more leading '#' so '## foo' renders as 'foo', not '# foo'.
		sed -n '/^# NAME$/,/^$/s/^#\{1,\}[[:space:]]\{0,1\}//p' "${0}"
		;;
	-*)
		# A pacman-style flag, not an apc command: pass straight through.
		pacman "${command}" "${cmd_args[@]}"
		;;
	*)
		# Not a command: treat it as a search term (apt-like default)
		search_packages "${command}" "${cmd_args[@]}"
		;;
	esac
}

# Handle keyboard interrupt and errors
trap 'echo "$(style "Interrupted by user" "${_yellow}")" >&2; exit 130' INT

main "$@"
